# eBay credentials for inventory sync (`npm run sync:ebay`)
# Copy to .env.local and fill in your values.
# Get credentials: https://developer.ebay.com/
# OAuth setup: npx ebay-mcp setup

EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_ENVIRONMENT=production
EBAY_USER_REFRESH_TOKEN=

# Optional: delay between GetItem calls (milliseconds)
EBAY_DETAIL_DELAY_MS=150

# Legacy aliases also supported by the sync script:
# EBAY_APP_ID=
# EBAY_CERT_ID=
